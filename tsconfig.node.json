{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "composite": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "types": ["node"],
    "strict": true,
    "emitDeclarationOnly": true,
    "outDir": "./node_modules/.tmp/tsnode",
    "tsBuildInfoFile": "./node_modules/.tmp/tsnode.tsbuildinfo"
  },
  "include": ["vite.config.ts"]
}
